{
  "name": "@tradebuddyhq/ebay-wrapper",
  "version": "2.0.0",
  "description": "Comprehensive, fully-typed eBay REST API wrapper for Node.js — Browse, Order, Inventory, Fulfillment, Account, Marketing, Finances, Taxonomy & more",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf lib && tsc",
    "clean": "rimraf lib",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ebay",
    "ebay-api",
    "ebay-sdk",
    "ebay-wrapper",
    "ebay-browse",
    "ebay-inventory",
    "ebay-fulfillment",
    "ebay-order",
    "ebay-taxonomy",
    "ebay-marketing",
    "ebay-account",
    "ebay-finances",
    "ebay-catalog",
    "ebay-rest-api",
    "marketplace",
    "ecommerce",
    "typescript"
  ],
  "author": "Trade Buddy <tradebuddyhq@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tradebuddyhq/ebay-wrapper"
  },
  "bugs": {
    "url": "https://github.com/tradebuddyhq/ebay-wrapper/issues"
  },
  "homepage": "https://github.com/tradebuddyhq/ebay-wrapper#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "typescript": "~5.6.0",
    "vitest": "^2.1.0"
  }
}
